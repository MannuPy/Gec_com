# ============================================================
# GesCom-BF — Variables d'environnement pour PythonAnywhere
# ============================================================
#
# Copier ce fichier vers `/home/<utilisateur>/gescom-bf/backend/.env`
# et adapter chaque valeur avant de demarrer l'application.
# NE JAMAIS committer ce fichier une fois rempli avec de vraies valeurs.
#
# Architecture PythonAnywhere (cf. docs/32-GUIDE-DEPLOIEMENT-PYTHONANYWHERE.md) :
#   - MySQL managé inclus dans le plan "Developer"
#   - Mode MONO-TENANT (multi-tenant PostgreSQL desactivé sur MySQL)
#   - Pas de Celery/Redis : taches via l'onglet "Tasks" (flask etl-daily, etc.)
#   - Frontend servi par Flask (SERVE_FRONTEND_DIST)

# ---- Base de donnees (MySQL manage PythonAnywhere) ----
# Format : mysql+pymysql://<user>:<mdp>@<user>.mysql.pythonanywhere-services.com/<user>$<base>?charset=utf8mb4
# Exemple : DATABASE_URL=mysql+pymysql://mannu:CHANGE_ME@mannu.mysql.pythonanywhere-services.com/mannu$gescom_bf?charset=utf8mb4
DATABASE_URL=mysql+pymysql://<utilisateur>:CHANGE_ME@<utilisateur>.mysql.pythonanywhere-services.com/<utilisateur>$gescom_bf?charset=utf8mb4

# Recycle les connexions avant le wait_timeout MySQL (280s < 8h par defaut).
# Deja active dans BaseConfig (pool_recycle=280). Decommenter pour surcharger.
# SQLALCHEMY_POOL_RECYCLE=280

# ---- Flask ----
FLASK_APP=wsgi.py
FLASK_ENV=production
# Generer avec : python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET

# ---- JWT (RG-36) ----
# Generer avec : python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ---- CORS ----
# Inutile si SERVE_FRONTEND_DIST sert le frontend depuis le meme domaine.
CORS_ORIGINS=https://<utilisateur>.pythonanywhere.com

# ---- Frontend servi par Flask (SPA React/Vite) ----
# Chemin absolu vers le build `frontend/dist` (apres `npm run build`).
SERVE_FRONTEND_DIST=/home/<utilisateur>/gescom-bf/frontend/dist

# ---- Compte administrateur initial (flask seed) ----
SEED_ADMIN_EMAIL=admin@votre-entreprise.bf
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- Documents PDF (recus de vente RF-19, exports rapports RF-29) ----
COMPANY_NAME=Votre Entreprise
COMPANY_ADDRESS=Ouagadougou, Burkina Faso
COMPANY_PHONE=+226 00 00 00 00

# ---- Tableau de bord vendeur (RF-VENDEUR-01) ----
# Taux de commission applique au CA mensuel pour la commission estimee.
COMMISSION_RATE=0.02
# Objectif mensuel de CA en FCFA pour la barre de progression.
VENDEUR_MONTHLY_TARGET=500000

# ---- Multi-tenant SaaS (ne pas modifier sur MySQL) ----
DEFAULT_TENANT_SCHEMA=public

# ---- Dashboard temps reel (SSE desactive sur PythonAnywhere/uWSGI) ----
# Mettre a true : le backend envoie 1 snapshot puis se ferme immediatement.
# Le frontend detecte l'event `sse-disabled` et bascule sur polling automatique.
DISABLE_SSE=true
DASHBOARD_STREAM_INTERVAL_SECONDS=5
DASHBOARD_STREAM_MAX_EVENTS=60

# ---- Machine Learning / MLflow ----
# Stocker les artefacts dans le dossier persistant du compte PythonAnywhere.
ML_ARTIFACT_DIR=/home/<utilisateur>/gescom-bf/backend/instance/ml_artifacts
MLFLOW_TRACKING_URI=file:/home/<utilisateur>/gescom-bf/backend/mlruns
MLFLOW_EXPERIMENT_NAME=gescom-bf

# ---- Celery/Redis ----
# Non utilises sur PythonAnywhere (taches CLI via l'onglet "Scheduled Tasks").
# Ne pas definir CELERY_BROKER_URL : aucune connexion Redis n'est etablie
# tant que les taches Celery ne sont pas appelees directement.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
