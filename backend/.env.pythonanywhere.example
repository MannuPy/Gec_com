# ============================================================
# GesCom-BF — Variables d'environnement pour PythonAnywhere
# ============================================================
#
# Copier ce fichier vers `/home/<utilisateur>/gescom-bf/backend/.env`
# (chemin chargé automatiquement par `load_dotenv()` dans app/config.py,
# cf. docs/25-DEPLOIEMENT-CICD.md §25.9). Adapter chaque valeur avant
# de démarrer l'application — NE JAMAIS committer ce fichier une fois
# rempli avec de vraies valeurs.
#
# Rappel architecture (cf. §25.9) :
#   - PythonAnywhere fournit une base MySQL managée incluse dans le plan
#     "Developer" (cf. onglet "Databases") : pas de PostgreSQL externe à
#     payer/configurer. Déploiement en mode MONO-TENANT (une seule base de
#     données = le tenant "public" applicatif, cf. app/utils/db_dialect.py
#     et app/models/company.py - `_PUBLIC_SCHEMA_ARGS`). Le mécanisme
#     multi-tenant schema-per-tenant (PostgreSQL) reste présent dans le code
#     mais désactivé (RF-01 self-service renvoie 503 sur MySQL, cf.
#     app/services/tenant_provisioning.py).
#   - Pas de worker Celery/Redis : les tâches ETL/ML sont exécutées via
#     les commandes Flask CLI (`flask etl-daily`, `flask ml-train-all`,
#     `flask ml-detect-anomalies`, cf. backend/app/cli.py) planifiées
#     dans l'onglet "Tasks" de PythonAnywhere.
#   - Le frontend (build Vite) est servi directement par Flask
#     (SERVE_FRONTEND_DIST) : un seul domaine, pas de CORS à configurer.

# ---- Base de données (MySQL managé PythonAnywhere) ----
# Format : mysql+pymysql://<utilisateur>:<motdepasse>@<utilisateur>.mysql.pythonanywhere-services.com/<utilisateur>$<base>?charset=utf8mb4
#
#   - <utilisateur>          : votre nom d'utilisateur PythonAnywhere (aussi
#                               l'hôte MySQL : <utilisateur>.mysql.pythonanywhere-services.com)
#   - <motdepasse>            : mot de passe MySQL défini dans l'onglet
#                               "Databases" (bouton "Set password", distinct
#                               du mot de passe du compte PythonAnywhere)
#   - <utilisateur>$<base>    : convention de nommage PythonAnywhere -
#                               ex. gescombf$gescom_bf (créée depuis l'onglet
#                               "Databases" -> "New database")
#   - charset=utf8mb4         : requis pour stocker tous les caractères
#                               unicode (emojis, accents mooré) sur 4 octets
#
# Exemple concret (utilisateur "gescombf", base "gescom_bf") :
#   DATABASE_URL=mysql+pymysql://gescombf:CHANGE_ME@gescombf.mysql.pythonanywhere-services.com/gescombf$gescom_bf?charset=utf8mb4
DATABASE_URL=mysql+pymysql://<utilisateur>:CHANGE_ME@<utilisateur>.mysql.pythonanywhere-services.com/<utilisateur>$gescom_bf?charset=utf8mb4

# Pool de connexions : MySQL ferme les connexions inactives après
# `wait_timeout` (8h par défaut, mais souvent réduit sur les hébergements
# partagés). `SQLALCHEMY_ENGINE_OPTIONS` (app/config.py) active déjà
# `pool_pre_ping=True` + `pool_recycle=280s` ; ajuster ce dernier via
# SQLALCHEMY_POOL_RECYCLE si nécessaire.
# SQLALCHEMY_POOL_RECYCLE=280

# ---- Flask ----
FLASK_APP=wsgi.py
FLASK_ENV=production
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET

# ---- JWT (RG-36) ----
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ---- CORS ----
# Inutile si SERVE_FRONTEND_DIST sert le frontend depuis le même domaine
# (déploiement recommandé). Sinon, lister le(s) domaine(s) du frontend.
CORS_ORIGINS=https://<utilisateur>.pythonanywhere.com

# ---- Frontend servi par Flask (SPA React/Vite) ----
# Chemin absolu vers le build `frontend/dist` (après `npm run build`,
# uploadé ou construit en CI puis copié sur PythonAnywhere).
SERVE_FRONTEND_DIST=/home/<utilisateur>/gescom-bf/frontend/dist

# ---- Compte administrateur initial (flask seed) ----
SEED_ADMIN_EMAIL=admin@votre-entreprise.bf
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- Documents PDF (reçus de vente RF-19, exports rapports RF-29) ----
COMPANY_NAME=Votre Entreprise
COMPANY_ADDRESS=Ouagadougou, Burkina Faso
COMPANY_PHONE=+226 00 00 00 00

# ---- Multi-tenant SaaS (RF-01, 27-MODELE-SAAS-MULTITENANT.md) ----
# En déploiement mono-tenant MySQL, "public" désigne simplement le tenant
# applicatif par défaut (aucun schéma PostgreSQL réel n'est créé) - cf.
# app/utils/tenant.py::set_search_path (no-op sur MySQL) et
# app/models/company.py. Ne pas modifier cette valeur sur PythonAnywhere.
DEFAULT_TENANT_SCHEMA=public

# ---- Machine Learning / MLflow (20-MACHINE-LEARNING.md, 21-PIPELINE-ETL.md) ----
# Stocker les artefacts dans le dossier persistant du compte PythonAnywhere.
ML_ARTIFACT_DIR=/home/<utilisateur>/gescom-bf/backend/instance/ml_artifacts
MLFLOW_TRACKING_URI=file:/home/<utilisateur>/gescom-bf/backend/mlruns
MLFLOW_EXPERIMENT_NAME=gescom-bf

# ---- Dashboard temps réel (22-DASHBOARD-BI.md §22.2, SSE) ----
# Le streaming SSE peut être limité par le proxy uWSGI de PythonAnywhere :
# le frontend bascule automatiquement sur le polling (reportsApi.realtime)
# si la connexion SSE échoue. Réduire la fréquence si nécessaire.
DASHBOARD_STREAM_INTERVAL_SECONDS=5
DASHBOARD_STREAM_MAX_EVENTS=60

# ---- Celery/Redis ----
# Non utilisés sur PythonAnywhere (remplacés par `flask etl-daily` /
# `flask ml-train-all` via les "Scheduled tasks"). Laisser les valeurs
# par défaut : aucune connexion Redis n'est établie tant que les tâches
# Celery ne sont pas appelées via un broker (`.run()` les exécute en
# synchrone, sans broker).
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=
