# ============================================================
# GesCom-BF — Variables d'environnement (exemple)
# Copier ce fichier vers ".env" et adapter les valeurs.
# Ne JAMAIS committer le fichier ".env" réel (secrets).
# ============================================================

# ---- Base de données ----
#
# DÉVELOPPEMENT LOCAL (Docker Compose) — PostgreSQL :
DATABASE_URL=postgresql+psycopg2://gescom:gescom_dev_password@db:5432/gescom_bf
#
# PRODUCTION PythonAnywhere — MySQL (décommenter et adapter) :
# DATABASE_URL=mysql+pymysql://<user>:<motdepasse>@<user>.mysql.pythonanywhere-services.com/<user>$gescom_bf?charset=utf8mb4
# Voir backend/.env.pythonanywhere.example et docs/32-GUIDE-DEPLOIEMENT-PYTHONANYWHERE.md

# ---- Redis (cache / Celery, utilisé en V2) ----
REDIS_URL=redis://redis:6379/0

# ---- Flask ----
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me-dev-secret-key

# ---- JWT (RG-36) ----
JWT_SECRET_KEY=change-me-dev-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173

# ---- Frontend ----
# Cible du proxy Vite pour /api/* (cf. frontend/vite.config.ts).
# En docker-compose, "api" est le nom du service backend sur le réseau interne.
# En exécution locale (sans Docker), utiliser http://localhost:5000.
VITE_API_PROXY_TARGET=http://api:5000

# Si défini et pointant vers un dossier existant (ex. /home/<user>/gescom-bf/frontend/dist
# après `npm run build`), Flask sert le SPA React/Vite + fallback index.html
# (cf. backend/app/__init__.py register_frontend). Laisser vide en dev
# (Vite dev server séparé sur :5173).
SERVE_FRONTEND_DIST=

# ---- Compte administrateur initial (script de seed) ----
SEED_ADMIN_EMAIL=admin@gescom-bf.bf
SEED_ADMIN_PASSWORD=Admin#2026

# ---- Documents PDF (reçus de vente RF-19, exports rapports RF-29) ----
COMPANY_NAME=Gescom BF
COMPANY_ADDRESS=Ouagadougou, Burkina Faso
COMPANY_PHONE=

# ---- Multi-tenant SaaS (RF-01, 27-MODELE-SAAS-MULTITENANT.md) ----
DEFAULT_TENANT_SCHEMA=public

# ---- Machine Learning / MLflow (20-MACHINE-LEARNING.md, 21-PIPELINE-ETL.md) ----
ML_ARTIFACT_DIR=instance/ml_artifacts
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=gescom-bf

# ---- Dashboard temps réel (22-DASHBOARD-BI.md §22.2, SSE) ----
DASHBOARD_STREAM_INTERVAL_SECONDS=5
DASHBOARD_STREAM_MAX_EVENTS=60

# ============================